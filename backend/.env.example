# Supabase credentials (find these in your Supabase project settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase direct Postgres URI (Dashboard → Settings → Database → Connection string)
# Used by PostgresSaver for persistent conversation memory.
SUPABASE_DB_URI=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

# Anthropic (Claude) — used by the LangChain agent
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI — used only for embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-ant-your-key-here

# LangSmith observability (sign up at smith.langchain.com)
LANGSMITH_API_KEY=lsv2_your-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=medical-voice-agent

# Clinic configuration
TIMEZONE=America/Chicago
SCHEDULING_HORIZON_DAYS=30
DEFAULT_SLOT_DURATION_MIN=30

# AssemblyAI speech-to-text 
ASSEMBLYAI_API_KEY=your_key_here

# Auth
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
